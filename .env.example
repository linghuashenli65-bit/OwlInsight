# ==============================================
# FinanceBot 环境配置
# ==============================================
# 将所有配置项复制到 .env（已排除在 git 外）后修改
# 配置项前缀：FINANCEBOT_
# 优先级：实际环境变量 > .env 文件 > 代码默认值
# ==============================================

# ──────────── LLM 配置 ────────────
FINANCEBOT_LLM_PROVIDER=openai          # openai | anthropic
FINANCEBOT_LLM_MODEL=gpt-4o
# FINANCEBOT_LLM_API_KEY=sk-xxx          # 也支持 OPENAI_API_KEY / ANTHROPIC_API_KEY
# FINANCEBOT_LLM_API_BASE=https://xxx    # 代理 / 自部署中转地址
FINANCEBOT_LLM_TEMPERATURE=0.1

# ──────────── Milvus 配置 ────────────
FINANCEBOT_MILVUS_URI=http://localhost:19530
FINANCEBOT_MILVUS_COLLECTION=finance_docs
FINANCEBOT_MILVUS_EMBEDDING_DIM=1024

# ──────────── 嵌入模型 ────────────
# 本地运行，首次使用会自动下载 huggingface 模型
FINANCEBOT_EMBEDDING_MODEL=BAAI/bge-m3
FINANCEBOT_RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# ──────────── 检索参数 ────────────
FINANCEBOT_RETRIEVAL_TOP_K=10
FINANCEBOT_RERANK_TOP_K=5
